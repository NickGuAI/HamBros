PORT=20001
HAMMURABI_ALLOWED_ORIGINS=http://localhost:5173
# Max concurrent agent sessions (default 10). New sessions return 429 when limit reached.
# HAMMURABI_MAX_AGENT_SESSIONS=20
# For Capacitor iOS app (bundled mode): add capacitor://localhost to allow CORS
# Example: http://localhost:5173,https://hammurabi.gehirn.ai,capacitor://localhost
# Internal API key for Command Room server-side session creation.
# Must include the agents:write scope.
HAMMURABI_INTERNAL_API_KEY=
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://hammurabi-api
AUTH0_CLIENT_ID=your-auth0-client-id
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_AUDIENCE=https://hammurabi-api
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
# Optional: GitHub Personal Access Token for Commander task fetching.
# Required if taskSource repos are private. Needs repo:read scope.
GITHUB_TOKEN=ghp_your_token_here
# Optional: Vercel integration for Service Manager.
# Team-level token with access to list projects/deployments and trigger deploys.
VERCEL_GEHIRN_MASTER_TOKEN=
VERCEL_GEHIRN_TEAM_ID=
# Commander data root (sessions.json, names.json, <commander-id>/.memory, <commander-id>/skills).
# Defaults to data/commanders when unset. `pnpm --filter hammurabi start` sets ~/.hammurabi/commander by default.
COMMANDER_DATA_DIR=${HOME}/.hammurabi/commander
# Optional machine identifier for machine-scoped S3 sync prefix.
# Defaults to HOSTNAME.
# COMMANDER_MACHINE_ID=gehirn-main-ec2
# Optional S3 durability controls.
# COMMANDER_S3_BUCKET=gehirn-hammurabi
# COMMANDER_S3_PREFIX=commander
# COMMANDER_S3_SYNC_ENABLED=1
# Optional: when set, used to encrypt sensitive settings (e.g. OpenAI transcription key).
# If unset, Hammurabi auto-generates a local key file at data/api-keys/transcription-secrets.key.
HAMMURABI_SETTINGS_ENCRYPTION_KEY=replace-with-a-long-random-secret
