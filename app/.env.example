PORT=20001
HAMBROS_ALLOWED_ORIGINS=http://localhost:5173
# For Capacitor iOS (bundled mode): add capacitor://localhost
# Example: http://localhost:5173,https://your-domain.com,capacitor://localhost
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://hambros-api
AUTH0_CLIENT_ID=your-auth0-client-id
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_AUDIENCE=https://hambros-api
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
# Required for Capacitor iOS production — point to your deployed HamBros server
VITE_APP_URL=
# Optional: GitHub PAT for Commander task fetching from private repos (repo:read scope)
GITHUB_TOKEN=ghp_your_token_here
# Optional: encryption key for sensitive settings (auto-generated if unset)
HAMBROS_SETTINGS_ENCRYPTION_KEY=replace-with-a-long-random-secret
